; Engine configuration file.
; Godot 4.x project file for ponGame by hamIDStudio

config_version=5

[application]

config/name="ponGame"
config/description="AI/ML belajar melalui Pong - oleh hamIDStudio"
run/main_scene="res://scenes/Loading.tscn"
config/features=PackedStringArray("4.3", "Mobile")
boot_splash/bg_color=Color(0.03, 0.03, 0.05, 1)
config/icon="res://icon.svg"

[autoload]

SaveManager="*res://scripts/autoload/SaveManager.gd"
GameState="*res://scripts/autoload/GameState.gd"
QLearning="*res://scripts/ai/QLearning.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/stretch/mode="viewport"
window/stretch/aspect="keep"
window/handheld/orientation="landscape"
window/dpi/allow_hidpi=true

[rendering]

renderer/rendering_method="mobile"
textures/canvas_textures/default_texture_filter=0

[input]

